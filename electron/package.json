{
  "name": "epigraph",
  "version": "0.1.0",
  "description": "Plateforme desktop d'analyse épidémiologique par GraphRAG",
  "main": "dist/main/main.js",
  "scripts": {
    "dev": "concurrently \"npm run dev:renderer\" \"wait-on http://localhost:5173 && npm run dev:main\"",
    "dev:renderer": "vite",
    "dev:main": "tsc -p tsconfig.main.json && electron .",
    "build": "npm run build:renderer && npm run build:main && electron-builder",
    "build:renderer": "vite build",
    "build:main": "tsc -p tsconfig.main.json",
    "lint": "eslint src --ext .ts,.tsx"
  },
  "dependencies": {
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "sigma": "^3.0.0",
    "@react-sigma/core": "^3.0.0",
    "graphology": "^0.25.0",
    "graphology-layout-forceatlas2": "^0.10.0",
    "zustand": "^4.5.0",
    "axios": "^1.7.0",
    "recharts": "^2.12.0"
  },
  "devDependencies": {
    "electron": "^31.0.0",
    "electron-builder": "^24.13.0",
    "vite": "^5.3.0",
    "@vitejs/plugin-react": "^4.3.0",
    "typescript": "^5.5.0",
    "concurrently": "^8.2.0",
    "wait-on": "^7.2.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "tailwindcss": "^3.4.0",
    "autoprefixer": "^10.4.0",
    "postcss": "^8.4.0"
  },
  "build": {
    "appId": "com.epigraph.app",
    "productName": "EpiGraph",
    "directories": {
      "output": "release"
    },
    "files": ["dist/**/*"],
    "linux": { "target": "AppImage" },
    "mac": { "target": "dmg" },
    "win": { "target": "nsis" }
  }
}
